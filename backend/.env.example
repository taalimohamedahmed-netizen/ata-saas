# ============================================================
# ATA Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to git.
# ============================================================

# ----- App -----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# ----- PostgreSQL -----
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ata

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0
# Session TTL in seconds (default 24h)
SESSION_TTL=86400

# ----- JWT / Auth -----
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
# Access token lifetime in minutes
JWT_EXPIRE_MINUTES=1440

# ----- Anthropic Claude -----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- WhatsApp Business API (Meta) -----
# Default fallback values; per-tenant credentials override these.
WHATSAPP_API_BASE=https://graph.facebook.com/v21.0
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ----- Shopify -----
SHOPIFY_API_VERSION=2024-10
# Used to validate Shopify webhook HMAC; per-tenant secret may override.
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret

# ----- Payments (Egypt) -----
# Default merchant numbers (per-tenant overrides stored in DB).
DEFAULT_INSTAPAY_NUMBER=
DEFAULT_VODAFONE_NUMBER=

# ----- CORS -----
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
